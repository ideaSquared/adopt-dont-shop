{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NODE_ENV", "CI", "DOCKER"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
      "env": ["NODE_ENV", "VITE_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "env": ["NODE_ENV", "VITE_*", "CHOKIDAR_USEPOLLING"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.tsx", "src/**/*.ts", "test/**/*.ts", "test/**/*.tsx"]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": [
        "CI",
        "E2E_API_URL",
        "E2E_CLIENT_URL",
        "E2E_ADMIN_URL",
        "E2E_RESCUE_URL",
        "E2E_RUN_ID"
      ]
    }
  }
}
