{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local", ".prettierrc", ".prettierignore", ".editorconfig"],
  "globalEnv": ["NODE_ENV", "CI", "DOCKER"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!.next/cache/**"],
      "env": ["NODE_ENV", "VITE_*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": [],
      "env": ["NODE_ENV", "VITE_*", "CHOKIDAR_USEPOLLING"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx",
        "vitest.config.ts",
        "package.json",
        "$TURBO_ROOT$/vitest.shared.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/coverage-thresholds.json"
      ]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**/*.tsx",
        "src/**/*.ts",
        "test/**/*.ts",
        "test/**/*.tsx",
        "$TURBO_ROOT$/vitest.shared.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/coverage-thresholds.json"
      ]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", "*.config.{js,ts,mjs}", "$TURBO_ROOT$/eslint.config.js"]
    },
    "format": {
      "outputs": [],
      "inputs": ["src/**", "package.json"]
    },
    "format:check": {
      "outputs": [],
      "inputs": ["src/**", "package.json"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": ["**/.tsbuildinfo", "dist/**/*.d.ts"]
    },
    "clean": {
      "cache": false
    },
    "test:e2e": {
      "cache": false,
      "dependsOn": ["^build"],
      "env": [
        "CI",
        "E2E_API_URL",
        "E2E_CLIENT_URL",
        "E2E_ADMIN_URL",
        "E2E_RESCUE_URL",
        "E2E_RUN_ID"
      ]
    }
  }
}
