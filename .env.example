# =============================================================================
# Adopt Don't Shop - Root Environment Configuration
# =============================================================================
# 👋 Quick start:
#   1. Copy this file to .env (or let `pnpm run setup` do it for you).
#   2. `pnpm run setup` auto-generates every secret in the "Auto-generated
#      secrets" block below — you don't need to hand-write those.
#   3. You're only responsible for POSTGRES_PASSWORD and any third-party
#      API keys you actually use. Everything else has a working dev default.
#
# This file only carries the essentials. Every other variable the stack
# reads — SMTP/SES, S3/CloudFront, Statsig, Sentry, OTel tracing, cron
# schedules, rate limiting, Turnstile, demo seeder counts, and more — is
# documented, grouped by domain, in docs/env-reference.md. Uncomment or
# add any of those keys here, or directly in your .env, only if you need
# to override the default.
#
# ⚠️ NEVER commit .env to version control. For production, use strong
# unique secrets (a secrets manager, not hand-typed values).
# =============================================================================
#
# =============================================================================
# REQUIRED — must be set before `pnpm docker:dev`
# =============================================================================
# `pnpm run setup` auto-generates every application secret in the
# "Auto-generated secrets" block below. The only value you MUST change by
# hand is POSTGRES_PASSWORD. Search this file for each REQUIRED key listed
# here to set or review it — none of them are "optional", regardless of
# section headers below.
#
#   * NODE_ENV
#   * POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB
#   * DB_HOST / DB_PORT / DB_USERNAME / DB_PASSWORD
#   * DEV_DB_NAME / TEST_DB_NAME / PROD_DB_NAME (per-NODE_ENV)
#   * JWT_SECRET / JWT_REFRESH_SECRET / SESSION_SECRET (auto-generated)
#   * ENCRYPTION_KEY (auto-generated)
#
# A CI guard (`scripts/check-env-example.mjs`) keeps this list in sync with
# `scripts/validate-env.ts` — add new required vars there and re-run
# `pnpm check:env-example` locally before pushing.
#
# =============================================================================
# OPTIONAL — change only if you know why
# =============================================================================
# Note: this section still contains the REQUIRED vars listed above (Postgres
# credentials, JWT/session secrets, etc.) — "optional" describes everything
# else in the file, not those keys.

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# -----------------------------------------------------------------------------
# Database (Postgres) — see docs/env-reference.md for pool/timeout tuning
# -----------------------------------------------------------------------------
POSTGRES_USER=adopt_user
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD_IMMEDIATELY
POSTGRES_DB=adopt_dont_shop_dev

# The backend selects ONE of DEV_DB_NAME / TEST_DB_NAME / PROD_DB_NAME based
# on NODE_ENV — there is no generic DB_NAME variable (ADS-409/452/465).
# NODE_ENV defaults to `development`, so the dev stack reads DEV_DB_NAME.
DB_HOST=database
DB_PORT=5432
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}
DEV_DB_NAME=${POSTGRES_DB}
TEST_DB_NAME=adopt_dont_shop_test
PROD_DB_NAME=adopt_dont_shop_prod

# -----------------------------------------------------------------------------
# Redis — see docs/env-reference.md for REDIS_HOST_PORT / REDIS_URL overrides
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Auto-generated secrets — `pnpm run setup` / `pnpm secrets:generate` replace
# every placeholder below. Safe to leave as-is if you're running setup.
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_THIS_TO_A_DIFFERENT_STRONG_RANDOM_SECRET
SESSION_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_SESSION_SECRET
# Must be exactly 64 hex characters (32 bytes) for AES-256 — generate with
# `pnpm secrets:generate`, don't hand-write it.
ENCRYPTION_KEY=CHANGE_ME_RUN_npm_run_secrets:generate
# Dedicated HMAC key for short-lived /uploads-signed/* URLs (ADS-542).
UPLOAD_SIGNING_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_UPLOAD_SIGNING_SECRET
# Signs read-only report-share JWTs. Optional — if missing, report sharing
# is silently disabled.
JWT_REPORT_SHARE_SECRET=CHANGE_THIS_TO_A_STRONG_RANDOM_REPORT_SHARE_SECRET
# REDIS_PASSWORD is required by docker-compose.yml (ADS-600) — Compose
# refuses to start without it.
REDIS_PASSWORD=CHANGE_THIS_SECURE_REDIS_PASSWORD
# Grafana admin password (docker-compose.yml `observability`/`full`
# profiles) — Compose refuses to start Grafana without it (ADS-968).
GF_SECURITY_ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_RANDOM_PASSWORD

# -----------------------------------------------------------------------------
# Frontend API configuration — used by all three apps (client/admin/rescue)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000
VITE_WS_BASE_URL=ws://localhost:4000

# Backend Frontend URLs (ADS-410: used to build password-reset /
# email-verification / invitation links — REQUIRED IN PRODUCTION, or every
# email link is broken).
FRONTEND_URL=http://localhost:3000
RESCUE_FRONTEND_URL=http://localhost:3002
ADMIN_FRONTEND_URL=http://localhost:3001

# Gateway self-URL (used in email/webhook callbacks). Required in production.
API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# CORS — every SPA origin that calls the gateway directly, comma-separated
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost,http://admin.localhost,http://rescue.localhost,http://api.localhost,http://localhost:4000

# -----------------------------------------------------------------------------
# Email — dev default prints to console. See docs/env-reference.md for
# Resend (the only production provider actually wired in) and the queue /
# webhook vars.
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@adoptdontshop.com
DEFAULT_FROM_EMAIL=noreply@adoptdontshop.com

# -----------------------------------------------------------------------------
# File storage — dev default is local disk. See docs/env-reference.md for
# the S3 + CloudFront vars.
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# Development options
# -----------------------------------------------------------------------------
# Force database seeding on startup (dev/test only — wipes + reseeds DB on
# every boot). Ignored when NODE_ENV=production.
FORCE_SEED=false

# Password assigned to every seeded user. If unset, the seeder generates a
# random password once and prints it to stdout.
SEED_PASSWORD=DevPassword123!

# ADS-512: include raw error messages in API responses. NEVER set to true
# in production — startup validation refuses to boot with
# DEBUG_ERRORS=true while NODE_ENV=production.
DEBUG_ERRORS=false
# =============================================================================
