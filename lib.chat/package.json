{
  "name": "@adopt-dont-shop/lib.chat",
  "version": "1.0.0",
  "description": "Real-time chat and messaging functionality",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
