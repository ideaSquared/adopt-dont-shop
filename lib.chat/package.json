    "@adopt-dont-shop/eslint-config-react": "*",
    "@adopt-dont-shop/lib.components": "*",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@testing-library/dom": "^9.3.4",
