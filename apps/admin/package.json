{
  "name": "@adopt-dont-shop/app.admin",
  "version": "1.0.0",
  "description": "Admin dashboard React application for platform management",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@adopt-dont-shop/lib.analytics": "workspace:*",
    "@adopt-dont-shop/lib.api": "workspace:*",
    "@adopt-dont-shop/lib.audit-logs": "workspace:*",
    "@adopt-dont-shop/lib.auth": "workspace:*",
    "@adopt-dont-shop/lib.chat": "workspace:*",
    "@adopt-dont-shop/lib.components": "workspace:*",
    "@adopt-dont-shop/lib.dev-tools": "workspace:*",
    "@adopt-dont-shop/lib.feature-flags": "workspace:*",
    "@adopt-dont-shop/lib.legal": "workspace:*",
    "@adopt-dont-shop/lib.moderation": "workspace:*",
    "@adopt-dont-shop/lib.observability": "workspace:*",
    "@adopt-dont-shop/lib.permissions": "workspace:*",
    "@adopt-dont-shop/lib.rescue": "workspace:*",
    "@adopt-dont-shop/lib.support-tickets": "workspace:*",
    "@adopt-dont-shop/lib.types": "workspace:*",
    "@adopt-dont-shop/lib.utils": "workspace:*",
    "@adopt-dont-shop/lib.validation": "workspace:*",
    "@statsig/react-bindings": "^3.33.1",
    "@tanstack/react-query": "^5.101.0",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "clsx": "^2.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-react": "workspace:*",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.9",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "prettier": "^3.2.5",
    "typescript": "^6.0.3",
