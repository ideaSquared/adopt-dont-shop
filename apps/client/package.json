{
  "name": "@adopt-dont-shop/app.client",
  "version": "1.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Public-facing React application for pet adoption",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@adopt-dont-shop/lib.analytics": "workspace:*",
    "@adopt-dont-shop/lib.api": "workspace:*",
    "@adopt-dont-shop/lib.applications": "workspace:*",
    "@adopt-dont-shop/lib.auth": "workspace:*",
    "@adopt-dont-shop/lib.chat": "workspace:*",
    "@adopt-dont-shop/lib.components": "workspace:*",
    "@adopt-dont-shop/lib.dev-tools": "workspace:*",
    "@adopt-dont-shop/lib.discovery": "workspace:*",
