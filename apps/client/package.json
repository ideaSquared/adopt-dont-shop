  "devDependencies": {
    "@adopt-dont-shop/eslint-config-react": "workspace:*",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
