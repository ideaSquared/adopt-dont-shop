# -----------------------------------------------------------------------------
# Backend notification provider configuration
# -----------------------------------------------------------------------------
# These supplement the root .env.example. The root file remains the canonical
# full environment template; this file documents the notification-delivery
# providers the backend reads and validates (see src/config/validate-env.ts).
#
# IMPORTANT: `console` is a DEV-ONLY provider for every channel below. It does
# not deliver to any real recipient — it logs (with PII redacted for SMS). The
# provider factories THROW in production when the provider is left as `console`,
# so production MUST set a real provider for each channel it uses.

# Email provider: console (DEV ONLY — does not send), ethereal (DEV preview),
# or resend. Production must set a real provider (resend).
EMAIL_PROVIDER=console

# SMS provider: console (DEV ONLY — logs a redacted line, does not deliver) or twilio.
# Production must set `twilio` (with TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN /
# TWILIO_FROM_NUMBER) — `console` is rejected in production.
SMS_PROVIDER=console
# SMS_DEFAULT_COUNTRY_CODE=44

# Push provider: console (DEV ONLY — logs, does not deliver) or fcm.
# Production must set `fcm` (with FCM_SERVICE_ACCOUNT_JSON / FCM_PROJECT_ID) —
# `console` is rejected in production. Note: only FcmPushProvider implements
# real delivery; there is no APNS provider yet.
PUSH_PROVIDER=console

# -----------------------------------------------------------------------------
# Observability / misc (validated as optional with safe defaults)
# -----------------------------------------------------------------------------
# Log verbosity: error | warn | info | http | debug | silly (default info)
LOG_LEVEL=info
# Bearer token guarding GET /metrics. Unset disables the Prometheus scrape route.
# METRICS_AUTH_TOKEN=CHANGE_THIS_METRICS_BEARER_TOKEN
# Sentry DSN for error reporting. Unset disables Sentry.
# SENTRY_DSN=your-sentry-dsn-url
# Anonymous swipe allowance before the swipe endpoint returns 402 (default 7).
ANON_SWIPE_LIMIT=7
