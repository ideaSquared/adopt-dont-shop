{
  "name": "@adopt-dont-shop/service-backend",
  "version": "1.0.0",
  "description": "Backend API service for Adopt Don't Shop",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --poll --watch src src/index.ts",
    "dev:fresh": "cross-env FORCE_SEED=true ts-node-dev --respawn --transpile-only --poll --watch src src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "clean": "rm -rf dist",
    "migrate": "sequelize-cli db:migrate",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo",
    "db:seed:reference": "ts-node src/seeders/cli.ts --reference",
    "db:seed:demo": "cross-env ALLOW_DEMO_SEED=true ts-node src/seeders/cli.ts --demo",
    "db:seed:fixtures": "ts-node src/seeders/cli.ts --fixtures",
    "db:seed:reset": "cross-env ALLOW_DEMO_SEED=true ts-node src/seeders/cli.ts --reset",
    "db:bootstrap": "cross-env ALLOW_BOOTSTRAP=true ts-node src/seeders/cli.ts --bootstrap",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "security:validate": "node scripts/validate-security.js",
    "docs:generate": "ts-node scripts/generate-swagger.ts generate",
    "docs:validate": "ts-node scripts/generate-swagger.ts validate",
    "docs:watch": "ts-node scripts/generate-swagger.ts watch",
    "prestart": "npm run security:validate",
    "predeploy": "npm run lint && npm run test && npm run security:validate && npm run build"
  },
  "dependencies": {
    "@adopt-dont-shop/lib.types": "*",
    "@adopt-dont-shop/lib.validation": "*",
    "@faker-js/faker": "^10.4.0",
    "@sentry/node": "^10.52.0",
    "@sentry/profiling-node": "^10.52.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.20.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^4.9.0",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "fs-extra": "^11.3.5",
    "helmet": "^7.0.0",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^3.12.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.3",
    "mjml": "^5.2.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "papaparse": "^5.4.1",
    "path": "^0.12.7",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^3.1.0",
    "sequelize": "^6.31.0",
    "sequelize-typescript": "^2.1.5",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-node": "*",
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/marked": "^6.0.0",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.0",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/pdfkit": "^0.13.4",
    "@types/qrcode": "^1.5.6",
    "@types/sequelize": "^4.28.20",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "@types/validator": "^13.7.10",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.0.8",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "sequelize-cli": "^6.6.0",
    "sqlite3": "^6.0.1",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.0.8"
  }
}
