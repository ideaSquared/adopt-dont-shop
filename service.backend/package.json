{
  "name": "@adopt-dont-shop/service-backend",
  "version": "1.0.0",
  "description": "Backend API service for Adopt Don't Shop",
  "main": "dist/index.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only --poll --watch src src/index.ts",
    "dev:fresh": "cross-env FORCE_SEED=true ts-node-dev --respawn --transpile-only --poll --watch src src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
    "clean": "rm -rf dist",
    "migrate": "ts-node src/migrations/runner.ts up",
    "db:migrate": "ts-node src/migrations/runner.ts up",
    "db:migrate:undo": "ts-node src/migrations/runner.ts down",
    "db:migrate:status": "ts-node src/migrations/runner.ts status",
    "seed": "cross-env ALLOW_DEMO_SEED=true ts-node src/seeders/cli.ts --reference --demo",
    "db:seed:reference": "ts-node src/seeders/cli.ts --reference",
    "db:seed:demo": "cross-env ALLOW_DEMO_SEED=true ts-node src/seeders/cli.ts --demo",
    "db:seed:fixtures": "ts-node src/seeders/cli.ts --fixtures",
    "db:seed:reset": "cross-env ALLOW_DEMO_SEED=true ts-node src/seeders/cli.ts --reset",
    "db:bootstrap": "cross-env ALLOW_BOOTSTRAP=true ts-node src/seeders/cli.ts --bootstrap",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "security:validate": "node scripts/validate-security.js",
    "docs:generate": "ts-node scripts/generate-swagger.ts generate",
    "docs:validate": "ts-node scripts/generate-swagger.ts validate",
    "docs:watch": "ts-node scripts/generate-swagger.ts watch",
    "legal-reminder:run": "ts-node src/workers/legal-reminder.cli.ts",
    "prestart": "npm run security:validate",
    "predeploy": "npm run lint && npm run test && npm run security:validate && npm run build"
  },
  "dependencies": {
    "@adopt-dont-shop/lib.types": "*",
    "@adopt-dont-shop/lib.validation": "*",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@sentry/node": "^10.55.0",
    "@sentry/profiling-node": "^10.55.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.77.7",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^5.5.0",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.0.0",
    "express-rate-limit": "^8.5.1",
    "express-validator": "^7.3.2",
    "file-type": "^22.0.1",
    "fs-extra": "^11.3.5",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "isomorphic-dompurify": "^3.15.0",
    "jsonwebtoken": "^9.0.3",
    "marked": "^18.0.4",
    "mjml": "^5.3.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.10",
    "otpauth": "^9.5.1",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.4",
    "sequelize": "^6.37.5",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-node": "*",
    "@faker-js/faker": "^10.4.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.13",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/marked": "^6.0.0",
    "@types/morgan": "^1.9.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "@types/validator": "^13.7.10",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vitest": "^4.0.8"
  }
}
