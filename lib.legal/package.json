{
  "name": "@adopt-dont-shop/lib.legal",
  "version": "1.0.0",
  "description": "Legal re-acceptance modal and consent service shared by every app",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "pet-adoption",
    "library",
    "typescript",
    "react",
    "legal",
    "consent"
  ],
  "author": "Adopt Don't Shop Team",
  "license": "MIT",
  "dependencies": {
    "@adopt-dont-shop/lib.api": "*",
    "@adopt-dont-shop/lib.auth": "*",
    "@adopt-dont-shop/lib.components": "*",
    "@adopt-dont-shop/lib.observability": "*",
    "@types/node": "^20.19.0",
    "@vanilla-extract/css": "^1.20.1",
    "react": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-base": "*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.8",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.8"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
