{
  "name": "@adopt-dont-shop/service.notifications",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "description": "Notifications service — the first stateful extraction (Phase 1). Owns the notifications.* schema (Notification, DeviceToken, UserNotificationPrefs, EmailPreference, EmailQueue), exposes gRPC for create/list/dismiss, subscribes to NATS for fan-out, and feeds the gateway's WebSocket spine. Phase 1.1 commit is just the boot skeleton + health endpoint — schema, gRPC, NATS, and gateway wiring land in subsequent commits.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch --import ./src/instrumentation.ts ./src/index.ts",
    "start": "node --import ./dist/instrumentation.js ./dist/index.js",
    "db:migrate": "tsx ./src/db/migrate.ts",
    "db:spam": "tsx ./src/db/spam.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:contracts:consumer": "vitest run --config vitest.contracts.config.ts --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@adopt-dont-shop/authz": "workspace:*",
    "@adopt-dont-shop/config-secrets": "workspace:*",
    "@adopt-dont-shop/db": "workspace:*",
    "@adopt-dont-shop/events": "workspace:*",
    "@adopt-dont-shop/lib.types": "workspace:*",
    "@adopt-dont-shop/observability": "workspace:*",
    "@adopt-dont-shop/proto": "workspace:*",
    "@adopt-dont-shop/seed-faker": "workspace:*",
    "@adopt-dont-shop/service-bootstrap": "workspace:*",
    "@grpc/grpc-js": "^1.14.4",
    "fastify": "^5.8.5",
    "nats": "^2.29.3",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "resend": "^6.14.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-node": "workspace:*",
    "@adopt-dont-shop/test-utils": "workspace:*",
    "@pact-foundation/pact": "^17.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.5"
  }
}
