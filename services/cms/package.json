{
  "name": "@adopt-dont-shop/service.cms",
  "version": "0.1.0",
  "private": true,
  "description": "CMS service — public content + admin CRUD + navigation menus. Owns the cms.* schema (cms_content, cms_navigation_menus). Public reads unauthenticated; admin writes gate on cms.content.* / cms.menu.* permissions; publish/unpublish/archive emit cms.* NATS events.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/server.ts",
      "import": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "start": "node ./dist/index.js",
    "db:migrate": "tsx ./src/db/migrate.ts",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@adopt-dont-shop/authz": "*",
    "@adopt-dont-shop/service-bootstrap": "*",
    "@adopt-dont-shop/config-secrets": "*",
    "@adopt-dont-shop/db": "*",
    "@adopt-dont-shop/events": "*",
    "@adopt-dont-shop/lib.types": "*",
    "@adopt-dont-shop/observability": "*",
    "@adopt-dont-shop/proto": "*",
    "@grpc/grpc-js": "^1.14.4",
    "fastify": "^5.8.5",
    "nats": "^2.29.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0"
  }
}
