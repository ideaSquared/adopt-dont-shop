{
  "name": "adopt-dont-shop-workspace",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "packageManager": "npm@10.8.1",
  "workspaces": [
    "app.admin",
    "app.client",
    "app.rescue",
    "eslint-config-base",
    "eslint-config-node",
    "eslint-config-react",
    "lib.analytics",
    "lib.api",
    "lib.applications",
    "lib.audit-logs",
    "lib.auth",
    "lib.chat",
    "lib.components",
    "lib.dev-tools",
    "lib.discovery",
    "lib.feature-flags",
    "lib.invitations",
    "lib.legal",
    "lib.moderation",
    "lib.notifications",
    "lib.observability",
    "lib.permissions",
    "lib.pets",
    "lib.rescue",
    "lib.search",
    "lib.support-tickets",
    "lib.types",
    "lib.utils",
    "lib.validation",
    "service.backend",
    "e2e"
  ],
  "scripts": {
    "setup": "node scripts/bootstrap.mjs",
    "prepare": "husky || true",
    "dev": "turbo run dev --parallel",
    "dev:apps": "turbo run dev --filter='@adopt-dont-shop/app.*' --parallel",
    "dev:backend": "turbo run dev --filter=@adopt-dont-shop/service-backend",
    "dev:services": "docker compose up -d database redis",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:dev:detach": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:shell:backend": "docker compose exec service-backend sh",
    "docker:shell:db": "docker compose exec database psql -U $POSTGRES_USER -d $POSTGRES_DB",
    "build": "turbo run build",
    "build:libs": "turbo run build --filter='@adopt-dont-shop/lib.*'",
    "build:apps": "turbo run build --filter='@adopt-dont-shop/app.*'",
    "test": "turbo run test",
    "test:e2e": "npm run -w @adopt-dont-shop/e2e test",
    "test:e2e:ui": "npm run -w @adopt-dont-shop/e2e test:ui",
    "test:e2e:debug": "npm run -w @adopt-dont-shop/e2e test:debug",
    "test:e2e:headed": "npm run -w @adopt-dont-shop/e2e test:headed",
    "test:e2e:report": "npm run -w @adopt-dont-shop/e2e report",
    "test:e2e:install": "npm run -w @adopt-dont-shop/e2e install:browsers",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .prettierignore",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "docker compose exec service-backend npm run migrate",
    "db:seed": "docker compose exec service-backend npm run seed",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "prod:build": "docker compose -f docker-compose.yml -f docker-compose.prod.yml build",
    "prod:up": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "prod:down": "docker compose -f docker-compose.yml -f docker-compose.prod.yml down",
    "secrets:generate": "node scripts/generate-secrets.mjs",
    "validate:env": "node scripts/validate-env.mjs",
    "check:lib-tests": "node scripts/check-lib-tests.mjs",
    "new-app": "node scripts/create-new-app.js",
    "new-lib": "node scripts/create-new-lib.js",
    "generate:attachments": "node scripts/generate-test-attachments.js"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "happy-dom": "^20.0.10",
    "husky": "^9.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.5",
    "turbo": "^2.9.14",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.0.8",
    "whatwg-fetch": "^3.6.20"
  },
  "overridesDocumentation": {
    "lodash": "Force lodash to >=4.17.21 to mitigate the prototype-pollution vulnerability tracked by CVE-2019-10744 / CVE-2020-8203 (GHSA-jf85-cpcp-j695, GHSA-p6mc-m468-83gw). The constraint is intentionally permissive (^4.18.1) so npm resolves the latest patched 4.x release across all transitive consumers. Do not remove without first verifying every transitive lodash dependency satisfies >=4.17.21.",
    "esbuild": "Pinned as a root devDependency (^0.27.0) — npm's workspace deduper uses the root version for every transitive consumer (notably @vanilla-extract/vite-plugin and @vanilla-extract/integration), which mitigates the dev-server CORS bypass tracked by GHSA-67mh-4wv8-2f99. Adding a separate `overrides` entry conflicts with the direct devDependency under npm 10/11; the devDep is enough on its own. Do not downgrade below 0.25.0."
  },
  "overrides": {
    "lodash": "^4.18.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --quiet"
    ],
    "**/*.{js,jsx,json,md,css}": [
      "prettier --write"
    ]
  }
}
