{
  "extends": "../../tsconfig.service.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    // Intentional override: this package is type-only test helpers, never
    // built to dist — noEmit:true overrides tsconfig.service.base.json's
    // noEmit:false.
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
