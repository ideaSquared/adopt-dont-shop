{
  "name": "@adopt-dont-shop/seed-faker",
  "version": "0.1.0",
  "private": true,
  "description": "Dev-only bulk-data ('spam') seeding toolkit: env-guard, seeded UK Faker, and a batched bulk-insert helper. Shared by each service's db:spam script. NEVER imported by runtime code — it exists purely to flood a development database with prod-shaped volume.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "production": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0"
  },
  "peerDependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.15.5",
    "pg": "^8.22.0"
  }
}
