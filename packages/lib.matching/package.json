{
  "name": "@adopt-dont-shop/lib.matching",
  "version": "1.0.0",
  "description": "Shared types for the AI/ML pet-adopter matching feature",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "pet-adoption",
    "matching",
    "ml",
    "library"
  ],
  "author": "Adopt Don't Shop Team",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-base": "workspace:*",
    "@types/node": "^25.9.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
