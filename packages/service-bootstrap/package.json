{
  "name": "@adopt-dont-shop/service-bootstrap",
  "version": "0.1.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "private": true,
  "description": "Shared boot mechanics for gRPC microservices \u2014 Fastify health server, gRPC bind/shutdown wrapper, gRPC adapter (adapt/adaptUnauth), principal extractor, HandlerError, and shutdown sequencer. Extracted from the 10 services that were copy-pasting the same ~200 lines.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "production": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@adopt-dont-shop/authz": "workspace:*",
    "@adopt-dont-shop/config-secrets": "workspace:*",
    "@adopt-dont-shop/lib.types": "workspace:*",
    "@adopt-dont-shop/observability": "workspace:*",
    "@grpc/grpc-js": "^1.14.4",
    "fastify": "^5.10.0",
    "nats": "^2.29.3",
    "pg": "^8.22.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "nats": "^2.29.3",
    "pg": "^8.22.0"
  },
  "peerDependenciesMeta": {
    "nats": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  }
}
