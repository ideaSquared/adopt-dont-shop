{
  "extends": "../../tsconfig.lib.base.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    // Intentional override: this lib ships source for Storybook/vite-plugin-dts
    // consumption rather than a tsc build — noEmit:true overrides
    // tsconfig.lib.base.json's noEmit:false.
    "noEmit": true,
    "outDir": "./dist",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules", "**/*.test.*", "**/*.spec.*"]
}
