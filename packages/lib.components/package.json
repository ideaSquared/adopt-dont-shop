{
  "name": "@adopt-dont-shop/lib.components",
  "version": "1.0.0",
  "description": "Shared component library for Adopt Don't Shop applications",
  "main": "dist/adopt-dont-shop-components.umd.js",
  "module": "dist/adopt-dont-shop-components.es.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "type": "module",
  "style": "dist/adopt-dont-shop-components.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/adopt-dont-shop-components.es.js",
      "require": "./dist/adopt-dont-shop-components.umd.js"
    },
    "./theme": {
      "import": "./dist/theme.es.js",
      "types": "./theme.d.ts"
    },
    "./styles": "./dist/adopt-dont-shop-components.css"
  },
  "files": [
    "dist",
    "theme.d.ts"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "dev:server": "vite --port 3010 --mode development",
    "build": "rimraf dist && vite build && tsc -p tsconfig.build.json && vite build --config vite.theme.config.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "clean": "rimraf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "dependencies": {
    "@adopt-dont-shop/lib.types": "workspace:*",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-world-flags": "^1.6.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-react": "workspace:*",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/global": "^5.0.0",
    "@storybook/react": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@types/react-world-flags": "^1.4.5",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "@vanilla-extract/vite-plugin": "^5.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@webcontainer/env": "^1.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "check-error": "^2.1.3",
    "deep-eql": "^5.0.2",
    "default-browser": "^5.5.0",
    "eslint-plugin-jest": "^29.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "identity-obj-proxy": "^3.0.0",
    "loupe": "^3.2.1",
    "pathval": "^2.0.1",
    "recast": "^0.23.11",
    "rimraf": "^6.1.3",
    "storybook": "^10.4.5",
    "ts-dedent": "^2.2.0",
    "use-sync-external-store": "^1.6.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.2",
    "wsl-utils": "^0.4.0"
  },
  "peerDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.16.0"
  }
}
