{
  "name": "@adopt-dont-shop/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Shared observability bootstrap for backend microservices — OpenTelemetry (OTLP/HTTP), Sentry (Node + profiling), and a Winston logger with optional Loki shipping. Mirrors service.backend's existing instrumentation/sentry/logger setup with the service name parameterised so every extracted service gets the same telemetry stack with one call.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "production": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@sentry/node": "^10.63.0",
    "@sentry/profiling-node": "^10.63.0",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0",
    "winston-loki": "^6.1.4"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  }
}
