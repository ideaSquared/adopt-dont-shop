{
  "name": "@adopt-dont-shop/lib.observability",
  "version": "1.0.0",
  "description": "Frontend observability helpers (Sentry init, Web Vitals reporter, consent gate)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css.ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css.ts}\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "observability",
    "sentry",
    "web-vitals",
    "react"
  ],
  "author": "Adopt Don't Shop Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/react": "^10.56.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-base": "workspace:*",
    "@types/react": "^19.2.15",
    "react": "^19.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "typescript": "^6.0.0"
  }
}
