{
  "name": "@adopt-dont-shop/lib.auth",
  "version": "1.0.0",
  "description": "Authentication and authorization functionality",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm clean && pnpm build"
  },
  "keywords": [
    "pet-adoption",
    "library",
    "typescript",
    "react"
  ],
  "author": "Adopt Don't Shop Team",
  "license": "MIT",
  "dependencies": {
    "@adopt-dont-shop/lib.api": "workspace:*",
    "@adopt-dont-shop/lib.components": "workspace:*",
    "@adopt-dont-shop/lib.permissions": "workspace:*",
    "@adopt-dont-shop/lib.types": "workspace:*",
    "@adopt-dont-shop/lib.validation": "workspace:*",
    "@vanilla-extract/css": "^1.20.1",
    "@vanilla-extract/recipes": "^0.5.7",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-base": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "react-dom": "^19.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ideaSquared/adopt-dont-shop.git",
    "directory": "lib.auth"
  },
  "bugs": {
    "url": "https://github.com/ideaSquared/adopt-dont-shop/issues"
  },
  "homepage": "https://github.com/ideaSquared/adopt-dont-shop/tree/main/lib.auth#readme"
}
