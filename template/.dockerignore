# Comprehensive .dockerignore for Turborepo monorepo

# Node.js
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Build outputs
dist
build
.next
out
*.tsbuildinfo

# Development files
.turbo
.vite
.cache
*.cache
.DS_Store
.idea
.vscode
*.swp
*.swo
*~

# Test files and coverage
coverage
*.lcov
.nyc_output
test-results
*.test.ts.snap

# Environment files (NEVER include in Docker image)
.env
.env.*
!.env.example
*.local

# Git files
.git
.gitignore
.gitattributes
.github

# Documentation
*.md
!README.md
docs
.claude

# CI/CD files
.gitlab-ci.yml
.travis.yml
circle.yml
azure-pipelines.yml

# Docker files (avoid recursion)
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs
*.log
pids
*.pid
*.seed
*.pid.lock

# Operating System files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
tmp
temp
*.tmp

# Database files
*.sqlite
*.sqlite3
*.db
db/data

# Media/Upload directories
uploads
public/uploads

# Package manager lock files
yarn.lock
pnpm-lock.yaml
