{
  "name": "@adopt-dont-shop/lib.observability",
  "version": "1.0.0",
  "description": "Frontend observability helpers (Sentry init, Web Vitals reporter, consent gate)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "observability",
    "sentry",
    "web-vitals",
    "react"
  ],
  "author": "Adopt Don't Shop Team",
  "license": "MIT",
  "dependencies": {
    "@sentry/react": "^10.0.0",
    "web-vitals": "^5.0.0"
  },
  "devDependencies": {
    "@adopt-dont-shop/eslint-config-base": "*",
    "@types/react": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.8"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "typescript": "^5.0.0"
  }
}
